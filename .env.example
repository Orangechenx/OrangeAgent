# ── LLM 模型配置（至少配一个） ──

# Claude（默认推荐）
ANTHROPIC_API_KEY=sk-ant-xxx
ORANGEAGENT_LITELLM_MODEL=anthropic/claude-sonnet-4-20250514

# GPT（备选）
# OPENAI_API_KEY=sk-xxx
# ORANGEAGENT_LITELLM_MODEL=openai/gpt-4o

# DeepSeek（高性价比，适合批量分析）
# DEEPSEEK_API_KEY=sk-xxx
# ORANGEAGENT_LITELLM_MODEL=deepseek/deepseek-chat

# ── 可选模型（取消注释即可切换） ──
# ORANGEAGENT_LITELLM_MODEL=openai/gpt-4o-mini        # 轻量快速
# ORANGEAGENT_LITELLM_MODEL=deepseek/deepseek-chat     # DeepSeek V3
# ORANGEAGENT_LITELLM_MODEL=anthropic/claude-sonnet-4  # 平衡
# ORANGEAGENT_LITELLM_MODEL=anthropic/claude-opus-4    # 最强

# ── OrangeAgent 配置 ──
ORANGEAGENT_DB_DIR=.orangeagent
ORANGEAGENT_VERIFY_ENABLED=true
ORANGEAGENT_VERIFY_MAX_RETRIES=3
