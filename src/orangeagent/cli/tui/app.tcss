Screen {
    layout: grid;
    grid-size: 2 2;
    grid-columns: 7fr 3fr;
    grid-rows: 1fr auto;
    background: #0d1117;
    border: solid #30363d;
}

Header {
    background: #161b22;
    color: #c9d1d9;
    text-style: bold;
}

Footer {
    background: #161b22;
    color: #8b949e;
}

#loading-label {
    column-span: 2;
    row-span: 1;
    height: 1;
    background: #0d1117;
    color: #8b949e;
    text-style: italic;
    padding: 0 1;
}

#messages {
    row-span: 1;
    column-span: 1;
    border: solid #30363d;
    padding: 1;
    background: #0d1117;
}

#messages .MessageHeader {
    color: #8b949e;
}

#messages Markdown {
    color: #c9d1d9;
}

#agents {
    row-span: 1;
    column-span: 1;
    border: solid #30363d;
    padding: 1;
    background: #0d1117;
}

AgentCard {
    border: solid #30363d;
    background: #161b22;
    padding: 1;
    margin: 0 0 1 0;
}

AgentCard .agent-name {
    color: #58a6ff;
    text-style: bold;
}

AgentCard .agent-status {
    color: #8b949e;
}

AgentCard .agent-task {
    color: #8b949e;
}

AgentCard .agent-conclusion {
    color: #6e7681;
}

InputArea {
    column-span: 2;
    max-height: 6;
    background: #161b22;
    border-top: solid #30363d;
}

InputArea TextArea {
    min-height: 1;
    max-height: 4;
    background: #0d1117;
    color: #c9d1d9;
    border: solid #30363d;
}

MessageWidget {
    background: transparent;
    padding: 0 1;
    margin: 0 0 1 0;
}

/* Human messages: blue left border */
.msg-human {
    border-left: thick #58a6ff;
}

/* Messages directed to human: green left border — these are the most important */
.msg-to-human {
    border-left: thick #3fb950;
}

/* Agent-to-agent messages: dimmer, visible but clearly internal comms */
.msg-agent {
    border-left: thick #484f58;
}

.msg-agent .MessageHeader {
    color: #6e7681;
}

.msg-agent Markdown {
    color: #8b949e;
}
