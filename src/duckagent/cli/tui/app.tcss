Screen {
    layout: grid;
    grid-size: 1 2;
    grid-rows: 1fr auto;
}

Header, Footer, #messages, VerticalScroll, Static, Markdown, MessageWidget, MessageHeader, InputArea {
    background: transparent;
}

#messages {
    row-span: 1;
    padding: 1;
}

InputArea {
    max-height: 6;
}

InputArea TextArea {
    min-height: 1;
    max-height: 4;
}
