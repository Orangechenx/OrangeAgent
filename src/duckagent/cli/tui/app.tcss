Screen {
    layout: grid;
    grid-size: 2 2;
    grid-columns: 7fr 3fr;
    grid-rows: 1fr auto;
    border: solid $surface-lighten-2;
}

Header, Footer, #messages, #agents, VerticalScroll, Static, Markdown, MessageWidget, MessageHeader, AgentCard, InputArea {
    background: transparent;
}

#messages {
    row-span: 1;
    column-span: 1;
    border: solid $surface-lighten-2;
    padding: 1;
}

#agents {
    row-span: 1;
    column-span: 1;
    border: solid $surface-lighten-2;
    padding: 1;
}

AgentCard {
    border: solid $surface-lighten-2;
}

InputArea {
    column-span: 2;
    max-height: 6;
}

InputArea TextArea {
    min-height: 1;
    max-height: 4;
}
